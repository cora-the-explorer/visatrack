# Database (Supabase Postgres) — optional in demo mode (file-backed store kicks in)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Auth (WorkOS) — unused in marketplace MVP, kept for future expansion
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback

# AI / Agents
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Marketplace MVP -----------------------------------------------------------
# Email delivery (Resend). If unset, sendEmail() console-logs and writes to
# logs/emails.jsonl so you can still trace what would have been sent.
RESEND_API_KEY=
EMAIL_FROM="VisaTrack <hello@visatrack.test>"

# Bearer token required to call POST /api/admin/firms/:id/approve.
# Manually approves a pending firm and emails them a magic link.
ADMIN_TOKEN=dev-admin
