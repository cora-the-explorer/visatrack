# --- Public site -----------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_FIRM_CONSOLE_URL=http://localhost:3000

# --- Supabase --------------------------------------------------------------
