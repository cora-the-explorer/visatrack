DIRECT_URL=

# --- Instagram scraper account --------------------------------------------
# Login-based scraping via Playwright. NOT a Meta API app.
# Use a dedicated burner IG account; expect occasional checkpoints / 2FA challenges.
IG_SCRAPER_USERNAME=
IG_SCRAPER_PASSWORD=
