{
  "name": "visa-track",
  "version": "0.1.0",
  "private": true,
  "description": "Visa Track Firm Console — multi-tenant SaaS for immigration law firms",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @visa-track/db generate",
    "db:migrate": "pnpm --filter @visa-track/db migrate",
    "db:studio": "pnpm --filter @visa-track/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "typescript": "^5.7.3"
  }
}
